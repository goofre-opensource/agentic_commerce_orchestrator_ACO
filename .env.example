# ─── Environment Configuration for Goofre ACO ────────────────────────────────
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control.

# ─── Mock Server ─────────────────────────────────────────────────────────────
# Port for the local mock insight API server
PORT=3001

# ─── Google Merchant Center (Optional — only needed for real integration) ─────
# Leave blank to run in MOCK mode (no API calls made)
GOOGLE_MERCHANT_ID=
GOOGLE_CREDENTIALS_PATH=

# ─── Webhook Security ─────────────────────────────────────────────────────────
# HMAC secrets for validating inbound webhooks from each platform
# Leave blank to disable HMAC validation (development only)
WEBHOOK_SECRET_GOOGLE_MERCHANT=
WEBHOOK_SECRET_SHOPIFY=
WEBHOOK_SECRET_SQUARE=

# ─── Development Flags ────────────────────────────────────────────────────────
NODE_ENV=development
ORCHESTRATOR_DEBUG=false
