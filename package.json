{
    "name": "agentic-commerce-orchestrator",
    "version": "1.0.0",
    "description": "Goofre Unified Commerce Protocol (UCP) — Open Source Core Engine",
    "private": true,
    "workspaces": [
        "packages/core-engine",
        "packages/plugins",
        "packages/mock-server",
        "apps/dashboard-lite"
    ],
    "scripts": {
        "build": "npm run build --workspaces",
        "dev": "npm run dev --workspace=packages/core-engine",
        "mock": "npm run start --workspace=packages/mock-server",
        "lint": "eslint 'packages/*/src/**/*.ts' 'tests/**/*.ts'",
        "typecheck": "tsc --noEmit",
        "test": "jest tests/integration/",
        "test:watch": "jest tests/integration/ --watch"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "@types/jest": "^29.0.0",
        "@types/node": "^20.0.0",
        "eslint": "^8.0.0",
        "eslint-config-prettier": "^9.0.0",
        "jest": "^29.0.0",
        "prettier": "^3.0.0",
        "ts-jest": "^29.0.0",
        "typescript": "^5.3.0"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "transform": {
            "^.+\\.tsx?$": [
                "ts-jest",
                {
                    "useESM": true
                }
            ]
        },
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        }
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=9.0.0"
    },
    "license": "MIT",
    "author": "Goofre, Inc.",
    "repository": {
        "type": "git",
        "url": "https://github.com/goofre-opensource/agentic_commerce_orchestrator_ACO.git"
    },
    "bugs": {
        "url": "https://github.com/goofre-opensource/agentic_commerce_orchestrator_ACO/issues"
    },
    "homepage": "https://github.com/goofre-opensource/agentic_commerce_orchestrator_ACO#readme",
    "keywords": [
        "commerce",
        "ucp",
        "orchestrator",
        "ai-agents",
        "gemini",
        "e-commerce",
        "agentic"
    ]
}