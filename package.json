{
  "name": "agentic-commerce-orchestrator",
  "version": "1.0.0",
  "description": "The premier Agentic Commerce Orchestrator (ACO) for Composable Architects.",
  "private": true,
  "workspaces": [
    "packages/core-engine",
    "packages/plugins",
    "packages/mock-server",
    "packages/create-goofre-ucp",
    "packages/interfaces",
    "apps/dashboard-lite"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "mock": "turbo run start --filter=@goofre/mock-server",
    "lint": "eslint . --ext .ts",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "validate": "turbo run build && npm run typecheck && npm run lint && npm run test",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "jest": "^29.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "turbo": "^1.10.16",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "./tests/tsconfig.json",
          "useESM": false
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "license": "BSL-1.1",
  "author": "Goofre, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/goofre-opensource/agentic_commerce_orchestrator_ACO.git"
  },
  "bugs": {
    "url": "https://github.com/goofre-opensource/agentic_commerce_orchestrator_ACO/issues"
  },
  "homepage": "https://github.com/goofre-opensource/agentic_commerce_orchestrator_ACO#readme",
  "keywords": [
    "commerce",
    "ucp",
    "orchestrator",
    "ai-agents",
    "gemini",
    "e-commerce",
    "agentic",
    "typescript",
    "agentic-commerce",
    "headless-ecommerce",
    "mcp-server"
  ]
}
